FROM node:22-alpine

WORKDIR /app

# Install necessary build tools, procps (required for Nx/ps command), and FFmpeg for audio extraction
RUN apk add --no-cache build-base python3 ffmpeg procps

COPY package.json package-lock.json* ./
RUN npm install --legacy-peer-deps

COPY . .

ENV CHOKIDAR_USEPOLLING=true

CMD ["npm", "run", "start:api"]