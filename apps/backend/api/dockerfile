# Build stage
FROM node:22-alpine AS builder

WORKDIR /app
COPY . .
RUN npm install --legacy-peer-deps
RUN npx nx build api

# Production stage
FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install --legacy-peer-deps

# Copy built output - FIXED PATH
COPY --from=builder /app/dist/apps/backend/api .

# FIXED ENTRY POINT
CMD ["node", "main.js"]