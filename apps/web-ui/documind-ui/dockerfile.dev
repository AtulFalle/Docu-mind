FROM node:22-slim

WORKDIR /app

# Install necessary build tools and procps (required for Nx/ps command)
RUN apt-get update && apt-get install -y python3 make g++ procps && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json* ./
RUN npm install --legacy-peer-deps

COPY . .

# Ensure the library is built before serving. Note: --host 0.0.0.0 is usually enough for Docker.
CMD ["sh", "-c", "npx nx build ui-material && npx nx serve documind-ui --host 0.0.0.0"]
