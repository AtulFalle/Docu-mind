# PRODUCTION-OPTIMIZED DOCKERFILE FOR NESTJS (Nx Monorepo)
# Uses Runner-side build & staging context.

FROM node:22-alpine

WORKDIR /app

# The context is a STAGING folder containing:
# 1. node_modules (pruned to production)
# 2. Pre-built application files (main.js, package.json, etc.)

ENV NODE_ENV=production

# Install FFmpeg for audio extraction
RUN apt-get update && apt-get install -y ffmpeg && rm -rf /var/lib/apt/lists/*

# Copy everything from the staging context
COPY . .

# Set entry point
# Assumes main.js is in the root of the staging folder
CMD ["node", "main.js"]
